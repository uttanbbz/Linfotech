<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login · Student Management System</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background: #F4F7FE;
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0;
        }
        .login-card {
            background: #fff;
            padding: 50px 40px;
            border-radius: 24px;
            box-shadow: 0 20px 50px rgba(112, 144, 176, 0.12);
            width: 100%;
            max-width: 420px;
            text-align: center;
        }
        .logo-box {
            width: 50px;
            height: 50px;
            background: linear-gradient(135deg, #FF9C00, #FFC048);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #fff;
            font-weight: 700;
            font-size: 22px;
            margin: 0 auto 20px auto;
        }
        h4 { color: #2B3674; font-weight: 700; }
        .subtext { color: #A3AED0; font-size: 14px; margin-bottom: 30px; }
        .form-control {
            background: #F8FAFC;
            border: 1px solid #E2E8F0;
            border-radius: 12px;
            padding: 12px 16px;
            font-size: 14px;
        }
        .form-control:focus {
            border-color: #6366F1;
            box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.15);
            background: #fff;
        }
        .form-label { font-size: 13px; font-weight: 600; color: #2B3674; }
        .btn-signin {
            background: #6366F1;
            color: #fff;
            border: none;
            border-radius: 12px;
            padding: 12px;
            font-weight: 600;
            width: 100%;
            margin-top: 10px;
            transition: background .2s;
        }
        .btn-signin:hover { background: #4F46E5; color: #fff; }
    </style>
</head>
<body>
    <div class="login-card">
        <div class="logo-box">S</div>
        <h4>Welcome Back</h4>
        <p class="subtext">Student Management System</p>

        <% if (error) { %>
            <div class="alert alert-danger py-2" style="font-size: 13px; border-radius: 12px;">
                <%= error %>
            </div>
        <% } %>

        <form method="POST" action="/login" class="text-start">
            <div class="mb-3">
                <label class="form-label">Email Address</label>
                <input type="text" name="email" class="form-control" placeholder="admin@gmail.com" required>
            </div>
            <div class="mb-3">
                <label class="form-label">Password</label>
                <input type="password" name="password" class="form-control" placeholder="••••••••" required>
            </div>
            <button type="submit" class="btn btn-signin">Sign In</button>
        </form>
    </div>
</body>
</html>
