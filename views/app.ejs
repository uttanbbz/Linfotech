<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SMS · <%= page.replace(/_/g, ' ') %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        :root {
            --sidebar-bg: #1B1C31;
            --sidebar-hover: #2B2DFB;
            --bg-color: #F4F7FE;
            --text-main: #2B3674;
            --text-muted: #A3AED0;
            --card-radius: 20px;
        }
        body { font-family: 'Inter', sans-serif; background: var(--bg-color); color: var(--text-main); }

        /* Sidebar */
        .sidebar {
            position: fixed; top: 0; left: 0; width: 280px; height: 100vh;
            background: var(--sidebar-bg); padding: 25px 20px;
            overflow-y: auto; z-index: 1000; display: flex; flex-direction: column;
        }
        .brand-box { display: flex; align-items: center; gap: 12px; margin-bottom: 35px; padding: 0 8px; }
        .brand-logo {
            width: 42px; height: 42px; border-radius: 12px; flex-shrink: 0;
            background: linear-gradient(135deg, #FF9C00, #FFC048);
            display: flex; align-items: center; justify-content: center;
            color: #fff; font-weight: 700; font-size: 18px;
        }
        .brand-text h6 { color: #fff; margin: 0; font-weight: 700; font-size: 15px; }
        .brand-text small { color: var(--text-muted); font-size: 11px; }
        .nav-header {
            color: var(--text-muted); font-size: 11px; font-weight: 600;
            letter-spacing: 1px; text-transform: uppercase; margin: 20px 8px 8px 8px;
        }
        .sidebar .nav-link {
            color: #B8B9CB; font-size: 14px; padding: 11px 14px; border-radius: 12px;
            display: flex; align-items: center; gap: 12px; margin-bottom: 4px; transition: all .2s;
        }
        .sidebar .nav-link i { width: 18px; text-align: center; }
        .sidebar .nav-link:hover { background: rgba(43, 45, 251, 0.25); color: #fff; }
        .sidebar .nav-link.active { background: var(--sidebar-hover); color: #fff; }
        .sidebar .nav-link.logout-link { color: #FF6B6B; }
        .sidebar .nav-link.logout-link:hover { background: rgba(255, 107, 107, 0.15); color: #FF6B6B; }
        .trophy-card {
            background: linear-gradient(135deg, #2B2DFB, #6366F1);
            border-radius: 16px; padding: 20px; text-align: center;
            color: #fff; margin-top: auto; margin-bottom: 15px;
        }
        .trophy-card i { font-size: 26px; color: #FFC048; margin-bottom: 8px; }

        /* Main */
        .main-content { margin-left: 280px; padding: 25px 30px; }
        .topbar { display: flex; align-items: center; justify-content: space-between; margin-bottom: 25px; flex-wrap: wrap; gap: 15px; }
        .page-title { font-weight: 700; text-transform: capitalize; margin: 0; }
        .welcome-text { color: var(--text-muted); font-size: 13px; }
        .topbar-tools { display: flex; align-items: center; gap: 10px; background: #fff; border-radius: 30px; padding: 8px 10px; box-shadow: 0 10px 30px rgba(112,144,176,0.10); }
        .search-box { background: var(--bg-color); border-radius: 30px; padding: 6px 15px; display: flex; align-items: center; gap: 8px; }
        .search-box input { border: none; background: transparent; outline: none; font-size: 13px; width: 140px; }
        .icon-btn { width: 36px; height: 36px; border-radius: 50%; border: none; background: transparent; color: var(--text-muted); position: relative; }
        .icon-btn .badge-dot {
            position: absolute; top: 2px; right: 2px; background: #FF4C61; color: #fff;
            font-size: 9px; border-radius: 50%; width: 15px; height: 15px;
            display: flex; align-items: center; justify-content: center;
        }
        .profile-btn { display: flex; align-items: center; gap: 10px; border: none; background: transparent; text-align: left; }
        .profile-btn img { width: 36px; height: 36px; border-radius: 50%; }
        .profile-btn .p-name { font-size: 13px; font-weight: 600; color: var(--text-main); line-height: 1.1; }
        .profile-btn .p-role { font-size: 11px; color: var(--text-muted); text-transform: capitalize; }

        /* Cards */
        .card { border: none; border-radius: var(--card-radius); box-shadow: 0 10px 30px rgba(112,144,176,0.08); }
        .card-header { background: #fff; border-bottom: 1px solid #F1F4F9; border-radius: var(--card-radius) var(--card-radius) 0 0 !important; font-weight: 700; }
        .table th { color: var(--text-muted); font-size: 12px; text-transform: uppercase; font-weight: 600; border: none; }
        .table td { vertical-align: middle; font-size: 14px; color: var(--text-main); }
        .form-label { font-size: 13px; font-weight: 600; }
        .form-control, .form-select { background: #F8FAFC; border: 1px solid #E2E8F0; border-radius: 12px; font-size: 14px; }
        .form-control:focus, .form-select:focus { border-color: #6366F1; box-shadow: 0 0 0 3px rgba(99,102,241,0.15); }

        /* Metric cards */
        .metric-card { border-radius: var(--card-radius); color: #fff; padding: 22px; position: relative; overflow: hidden; }
        .metric-card .m-icon {
            width: 46px; height: 46px; border-radius: 50%; background: rgba(255,255,255,0.25);
            display: flex; align-items: center; justify-content: center; font-size: 18px; margin-bottom: 12px;
        }
        .metric-card h3 { font-weight: 700; margin: 0; }
        .metric-card small { opacity: .85; font-size: 12px; }
        .bg-purple { background: linear-gradient(135deg, #6366F1, #818CF8); }
        .bg-green  { background: linear-gradient(135deg, #00B87C, #34D39E); }
        .bg-orange { background: linear-gradient(135deg, #FF9C00, #FFC048); }
        .bg-blue   { background: linear-gradient(135deg, #0075FF, #4DA3FF); }
        .bg-pink   { background: linear-gradient(135deg, #FF4C61, #FF7E8D); }

        .status-pill { font-size: 11px; font-weight: 600; padding: 5px 12px; border-radius: 20px; }
        .pill-green { background: #E6F9F1; color: #00B87C; }
        .pill-red   { background: #FFECEE; color: #FF4C61; }
        .pill-yellow{ background: #FFF6E0; color: #E5A100; }

        .avatar-sm { width: 34px; height: 34px; border-radius: 50%; }
        .notif-card { background: #fff; border-radius: 16px; padding: 18px 20px; box-shadow: 0 10px 30px rgba(112,144,176,0.08); display: flex; gap: 15px; align-items: flex-start; margin-bottom: 12px; }
        .notif-icon { width: 42px; height: 42px; border-radius: 12px; background: #EEF0FF; color: #6366F1; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
        .score-card { background: #fff; border-radius: var(--card-radius); box-shadow: 0 10px 30px rgba(112,144,176,0.08); border-top: 5px solid #6366F1; padding: 25px; text-align: center; }
        .btn-indigo { background: #6366F1; color: #fff; border-radius: 12px; }
        .btn-indigo:hover { background: #4F46E5; color: #fff; }
    </style>
</head>
<body>

<!-- ================= SIDEBAR ================= -->
<div class="sidebar">
    <div class="brand-box">
        <div class="brand-logo">S</div>
        <div class="brand-text">
            <h6>SMS</h6>
            <small>Management System</small>
        </div>
    </div>

    <a href="/app?page=dashboard" class="nav-link <%= page === 'dashboard' ? 'active' : '' %>">
        <i class="fa-solid fa-house"></i> Dashboard
    </a>

    <% if (user.role === 'admin') { %>
        <div class="nav-header">Academic</div>
        <a href="/app?page=courses" class="nav-link <%= page === 'courses' ? 'active' : '' %>"><i class="fa-solid fa-book"></i> Courses</a>
        <a href="/app?page=subjects" class="nav-link <%= page === 'subjects' ? 'active' : '' %>"><i class="fa-solid fa-book-open"></i> Subjects</a>
        <a href="/app?page=manage_attendance" class="nav-link <%= page === 'manage_attendance' ? 'active' : '' %>"><i class="fa-solid fa-clipboard-user"></i> Manage Attendance</a>
        <a href="/app?page=manage_exams" class="nav-link <%= page === 'manage_exams' ? 'active' : '' %>"><i class="fa-solid fa-file-pen"></i> Manage Exams</a>
        <div class="nav-header">Users</div>
        <a href="/app?page=manage_staff" class="nav-link <%= page === 'manage_staff' ? 'active' : '' %>"><i class="fa-solid fa-user-tie"></i> Manage Staff</a>
        <a href="/app?page=manage_students" class="nav-link <%= page === 'manage_students' ? 'active' : '' %>"><i class="fa-solid fa-user-graduate"></i> Manage Students</a>
        <div class="nav-header">Requests</div>
        <a href="/app?page=notifications" class="nav-link <%= page === 'notifications' ? 'active' : '' %>"><i class="fa-solid fa-envelope-open-text"></i> Leave Requests</a>
        <a href="/app?page=notify" class="nav-link <%= page === 'notify' ? 'active' : '' %>"><i class="fa-solid fa-bullhorn"></i> Send Notice</a>
    <% } else if (user.role === 'staff') { %>
        <div class="nav-header">Academic</div>
        <a href="/app?page=take_attendance" class="nav-link <%= page === 'take_attendance' ? 'active' : '' %>"><i class="fa-solid fa-clipboard-check"></i> Take Attendance</a>
        <a href="/app?page=view_attendance" class="nav-link <%= page === 'view_attendance' ? 'active' : '' %>"><i class="fa-solid fa-list-check"></i> View Attendance</a>
        <a href="/app?page=manage_exams" class="nav-link <%= page === 'manage_exams' ? 'active' : '' %>"><i class="fa-solid fa-file-pen"></i> Manage Exams</a>
        <div class="nav-header">Requests</div>
        <a href="/app?page=apply_leave" class="nav-link <%= page === 'apply_leave' ? 'active' : '' %>"><i class="fa-solid fa-calendar-minus"></i> Apply Leave</a>
        <div class="nav-header">Others</div>
        <a href="/app?page=staff_notifs" class="nav-link <%= page === 'staff_notifs' ? 'active' : '' %>"><i class="fa-solid fa-bell"></i> Notices</a>
    <% } else { %>
        <div class="nav-header">Academic</div>
        <a href="/app?page=my_attendance" class="nav-link <%= page === 'my_attendance' ? 'active' : '' %>"><i class="fa-solid fa-clipboard-user"></i> My Attendance</a>
        <a href="/app?page=exam_results" class="nav-link <%= page === 'exam_results' ? 'active' : '' %>"><i class="fa-solid fa-square-poll-vertical"></i> Exam Results</a>
        <div class="nav-header">Requests</div>
        <a href="/app?page=apply_leave" class="nav-link <%= page === 'apply_leave' ? 'active' : '' %>"><i class="fa-solid fa-calendar-minus"></i> Apply Leave</a>
        <div class="nav-header">Others</div>
        <a href="/app?page=student_notifs" class="nav-link <%= page === 'student_notifs' ? 'active' : '' %>"><i class="fa-solid fa-bell"></i> Notices</a>
        <a href="/app?page=feedback" class="nav-link <%= page === 'feedback' ? 'active' : '' %>"><i class="fa-solid fa-comment-dots"></i> Feedback</a>
    <% } %>

    <div class="trophy-card">
        <i class="fa-solid fa-trophy"></i>
        <div style="font-weight:700; font-size:14px;">Keep it up!</div>
        <small style="opacity:.8; font-size:11px;">You're doing great this semester.</small>
    </div>

    <a href="/logout" class="nav-link logout-link"><i class="fa-solid fa-right-from-bracket"></i> Logout</a>
</div>

<!-- ================= MAIN ================= -->
<div class="main-content">

    <!-- Top navbar -->
    <div class="topbar">
        <div>
            <h4 class="page-title"><%= page.replace(/_/g, ' ') %></h4>
            <span class="welcome-text">Welcome back, <%= user.full_name %>! 👋</span>
        </div>
        <div class="topbar-tools">
            <div class="search-box">
                <i class="fa-solid fa-magnifying-glass" style="color:var(--text-muted); font-size:13px;"></i>
                <input type="text" placeholder="Search...">
            </div>
            <button class="icon-btn"><i class="fa-regular fa-calendar"></i></button>
            <button class="icon-btn"><i class="fa-regular fa-bell"></i><span class="badge-dot">3</span></button>
            <button class="profile-btn">
                <img src="https://ui-avatars.com/api/?name=<%= encodeURIComponent(user.full_name || 'User') %>&background=6366F1&color=fff" alt="avatar">
                <span>
                    <span class="p-name d-block"><%= user.full_name %></span>
                    <span class="p-role d-block"><%= user.role %></span>
                </span>
            </button>
        </div>
    </div>

    <!-- Success alert -->
    <% if (success_msg) { %>
        <div class="alert alert-success alert-dismissible fade show" style="border-radius:14px; border:none;">
            <i class="fa-solid fa-circle-check me-2"></i><%= success_msg %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    <% } %>

    <!-- ============ PAGE CONTENT ============ -->

    <% if (page === 'dashboard') { %>
        <%
            let attPct;
            if (user.role === 'student' && typeof total_total !== 'undefined') {
                attPct = total_total > 0 ? Math.round((total_present / total_total) * 100) : 0;
            } else {
                attPct = (typeof att_count !== 'undefined' && att_count > 0) ? 87 : 0;
            }
        %>
        <div class="row g-3 mb-4">
            <div class="col">
                <div class="metric-card bg-purple">
                    <div class="m-icon"><i class="fa-solid fa-book"></i></div>
                    <h3><%= typeof total_courses !== 'undefined' ? total_courses : 12 %></h3>
                    <small>Total Courses</small>
                </div>
            </div>
            <div class="col">
                <div class="metric-card bg-green">
                    <div class="m-icon"><i class="fa-solid fa-book-open"></i></div>
                    <h3><%= typeof total_subjects !== 'undefined' ? total_subjects : 36 %></h3>
                    <small>Total Subjects</small>
                </div>
            </div>
            <div class="col">
                <div class="metric-card bg-orange">
                    <div class="m-icon"><i class="fa-solid fa-clipboard-user"></i></div>
                    <h3><%= attPct %>%</h3>
                    <small>Attendance</small>
                </div>
            </div>
            <div class="col">
                <div class="metric-card bg-blue">
                    <div class="m-icon"><i class="fa-solid fa-user-graduate"></i></div>
                    <h3><%= typeof total_students !== 'undefined' ? total_students : 480 %></h3>
                    <small>Total Students</small>
                </div>
            </div>
            <div class="col">
                <div class="metric-card bg-pink">
                    <div class="m-icon"><i class="fa-solid fa-user-tie"></i></div>
                    <h3><%= typeof total_staff !== 'undefined' ? total_staff : 25 %></h3>
                    <small>Total Staff</small>
                </div>
            </div>
        </div>

        <div class="row g-3">
            <div class="col-lg-8">
                <div class="card p-4">
                    <h6 class="fw-bold mb-3">Attendance Overview</h6>
                    <div style="position:relative; height:320px;">
                        <canvas id="attChart"></canvas>
                    </div>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="card p-4">
                    <h6 class="fw-bold mb-3">Performance Metrics</h6>
                    <div style="position:relative; height:320px;">
                        <canvas id="perfChart"></canvas>
                    </div>
                </div>
            </div>
        </div>

    <% } else if (page === 'courses' || page === 'subjects') { %>
        <div class="row g-3">
            <div class="col-lg-4">
                <div class="card p-4">
                    <h6 class="fw-bold mb-3">Add New <%= page === 'courses' ? 'Course' : 'Subject' %></h6>
                    <form method="POST" action="/app?page=<%= page %>">
                        <input type="hidden" name="action" value="<%= page === 'courses' ? 'add_course' : 'add_subject' %>">
                        <div class="mb-3">
                            <label class="form-label"><%= page === 'courses' ? 'Course' : 'Subject' %> Name</label>
                            <input type="text" name="name" class="form-control" required>
                        </div>
                        <% if (page === 'subjects') { %>
                            <div class="mb-3">
                                <label class="form-label">Course</label>
                                <select name="course_id" class="form-select" required>
                                    <option value="">-- Select Course --</option>
                                    <% courses.forEach(c => { %>
                                        <option value="<%= c._id %>"><%= c.name %></option>
                                    <% }) %>
                                </select>
                            </div>
                        <% } %>
                        <button class="btn btn-indigo w-100 rounded-3"><i class="fa-solid fa-plus me-2"></i>Add</button>
                    </form>
                </div>
            </div>
            <div class="col-lg-8">
                <div class="card p-4">
                    <h6 class="fw-bold mb-3">All <%= page === 'courses' ? 'Courses' : 'Subjects' %></h6>
                    <div class="table-responsive">
                        <table class="table align-middle">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>Name</th>
                                    <% if (page === 'subjects') { %><th>Course</th><% } %>
                                    <th class="text-end">Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% const items = (page === 'courses') ? courses : subjects; %>
                                <% items.forEach((item, i) => { %>
                                    <tr>
                                        <td><%= i + 1 %></td>
                                        <td class="fw-semibold"><%= item.name %></td>
                                        <% if (page === 'subjects') { %>
                                            <td><span class="status-pill pill-green"><%= item.course_id ? item.course_id.name : 'N/A' %></span></td>
                                        <% } %>
                                        <td class="text-end">
                                            <a href="/app?delete=1&table=<%= page %>&id=<%= item._id %>&page=<%= page %>"
                                               class="btn btn-sm btn-outline-danger rounded-3"
                                               onclick="return confirm('Delete this record?')">
                                                <i class="fa-solid fa-trash"></i>
                                            </a>
                                        </td>
                                    </tr>
                                <% }) %>
                                <% if (items.length === 0) { %>
                                    <tr><td colspan="4" class="text-center text-muted py-4">No records found.</td></tr>
                                <% } %>
                            </tbody>
                       
